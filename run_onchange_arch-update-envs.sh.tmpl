#!/bin/bash
# ~/.local/share/chezmoi/run_onchange_setup-shell-env.sh.tmpl
{{ $paths := .shell.paths }}
{{ $envVars := .shell.envVars }}

set -e

# Generate fish commands
FISH_CONFIG="{{ .chezmoi.homeDir }}/.config/fish/conf.d/chezmoi-env.fish"
mkdir -p "$(dirname "$FISH_CONFIG")"

cat > "$FISH_CONFIG" << EOF
# Generated by chezmoi - do not edit manually
{{ range $paths -}}
{{ $expanded := . | replace "~" $.chezmoi.homeDir -}}
test -d {{ $expanded }}; and fish_add_path {{ $expanded }}
{{ end -}}

{{ range $key, $val := $envVars -}}
set -gx {{ $key }} "{{ $val }}"
{{ end -}}
EOF

# Generate bash env file
BASH_ENV="{{ .chezmoi.homeDir }}/.config/shell-env.sh"
mkdir -p "$(dirname "$BASH_ENV")"

cat > "$BASH_ENV" << EOF
# Generated by chezmoi - do not edit manually
{{ range $paths -}}
{{ $expanded := . | replace "~" $.chezmoi.homeDir -}}
[ -d "{{ $expanded }}" ] && export PATH="{{ $expanded }}:\$PATH"
{{ end -}}

{{ range $key, $val := $envVars -}}
export {{ $key }}="{{ $val }}"
{{ end -}}
EOF